# Copy this file to .env.local and fill in your real keys
# NEVER commit .env.local to git

# Stripe — get these from dashboard.stripe.com
# Use the TEST keys during development (prefix sk_test_ / pk_test_)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Resend — get your API key from resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_YOUR_KEY_HERE

# Your live domain (no trailing slash) — used for Stripe redirect URLs
NEXT_PUBLIC_BASE_URL=https://bowdesignuk.com
